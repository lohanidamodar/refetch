# ---------------------------------------------------------------
# Fastfile — iOS build & deployment lanes
# ---------------------------------------------------------------
# This file is designed to be project-agnostic. All project-specific
# values (bundle ID, app name, workspace, scheme) are read from
# environment variables so the same file can be dropped into any
# Flutter project.
#
# Required env vars:
#   APP_IDENTIFIER                 — iOS bundle identifier (e.g. com.example.app)
#   APP_STORE_CONNECT_KEY_ID       — App Store Connect API key ID
#   APP_STORE_CONNECT_ISSUER_ID    — App Store Connect issuer ID
#   APP_STORE_CONNECT_KEY_CONTENT  — Base64-encoded .p8 private key content
#   MATCH_GIT_URL                  — SSH URL of private match certificates repo
#   MATCH_PASSWORD                 — Passphrase for the match repo
#   TEAM_ID                        — Apple Developer Team ID
#
# Optional env vars (sensible Flutter defaults applied if unset):
#   APP_NAME         — Output IPA name (default: "Runner")
#   IOS_WORKSPACE    — Xcode workspace filename (default: "Runner.xcworkspace")
#   IOS_SCHEME       — Xcode scheme name (default: "Runner")
# ---------------------------------------------------------------

default_platform(:ios)

# ------------------------------------------------------------------
# Helpers: resolve project-agnostic values from the environment
# ------------------------------------------------------------------
def app_identifier_value
  value = ENV["APP_IDENTIFIER"]
  UI.user_error!("APP_IDENTIFIER env var must be set (iOS bundle ID)") if value.nil? || value.empty?
  value
end

def ios_workspace
  # Default "Runner.xcworkspace" is the Flutter convention; override
  # with IOS_WORKSPACE if the project uses something else.
  ENV["IOS_WORKSPACE"] || "Runner.xcworkspace"
end

def ios_scheme
  # Default "Runner" is the Flutter convention; override with IOS_SCHEME.
  ENV["IOS_SCHEME"] || "Runner"
end

def ipa_output_name
  # Strip any ".ipa" the user may have added and always append it here.
  base = (ENV["APP_NAME"] || "Runner").sub(/\.ipa\z/i, "")
  "#{base}.ipa"
end

def appstore_profile_name(app_id)
  "match AppStore #{app_id}"
end

def appstore_export_options(app_id)
  {
    signingStyle: "manual",
    provisioningProfiles: {
      app_id => appstore_profile_name(app_id),
    },
  }
end

platform :ios do
  # ------------------------------------------------------------------
  # Helper: Build the App Store Connect API key from environment vars
  # ------------------------------------------------------------------
  desc "Create App Store Connect API key object from env vars"
  private_lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY_CONTENT"],  # base64-encoded .p8 key
      is_key_content_base64: true,
      in_house: false,
    )
  end

  # ------------------------------------------------------------------
  # Helper: Sync signing via match
  # ------------------------------------------------------------------
  desc "Sync code signing certificates and profiles via match"
  private_lane :sync_signing do
    load_asc_api_key

    match(
      type: "appstore",
      readonly: is_ci,  # CI should never create new profiles
      app_identifier: app_identifier_value,
      git_url: ENV["MATCH_GIT_URL"],
    )
  end

  # ------------------------------------------------------------------
  # Beta: Build + upload to TestFlight
  # ------------------------------------------------------------------
  desc "Build and upload to TestFlight"
  lane :beta do
    sync_signing

    app_id = app_identifier_value

    # Build the Flutter-generated Xcode project.
    # Workspace/scheme default to the Flutter standard ("Runner.xcworkspace"/"Runner")
    # but can be overridden via IOS_WORKSPACE / IOS_SCHEME env vars.
    build_app(
      workspace: ios_workspace,
      scheme: ios_scheme,
      export_method: "app-store",
      export_options: appstore_export_options(app_id),
      output_directory: "../build/ios",
      output_name: ipa_output_name,
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end

  # ------------------------------------------------------------------
  # Release: Build + upload to App Store for review
  # ------------------------------------------------------------------
  desc "Build and upload to App Store"
  lane :release do
    sync_signing

    app_id = app_identifier_value

    build_app(
      workspace: ios_workspace,
      scheme: ios_scheme,
      export_method: "app-store",
      export_options: appstore_export_options(app_id),
      output_directory: "../build/ios",
      output_name: ipa_output_name,
    )

    upload_to_app_store(
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: "./fastlane/metadata",
      force: true,  # skip HTML preview confirmation
      ignore_language_directory_validation: true,
      precheck_include_in_app_purchases: false,
    )
  end

  # ------------------------------------------------------------------
  # Fetch Apple account info via Spaceship (used by ios_setup_env.sh)
  # ------------------------------------------------------------------
  desc "Fetch ITC Team ID and verify app in App Store Connect"
  lane :fetch_apple_info do
    require "spaceship"

    apple_id = ENV["APPLE_ID"]
    app_id   = ENV["APP_IDENTIFIER"]

    UI.user_error!("APPLE_ID env var is required") unless apple_id
    UI.user_error!("APP_IDENTIFIER env var is required") unless app_id

    UI.message("Authenticating as #{apple_id} ...")
    Spaceship::ConnectAPI.login(apple_id)

    # Fetch ITC Team ID
    itc_team_id = ""
    begin
      tunes_client = Spaceship::Tunes.client rescue nil
      if tunes_client && tunes_client.teams && tunes_client.teams.length > 0
        team = tunes_client.teams.first
        itc_team_id = team["contentProvider"]["contentProviderId"].to_s
        UI.success("ITC_TEAM_ID: #{itc_team_id}")
      end
    rescue => e
      UI.important("Could not fetch ITC Team ID: #{e.message}")
    end

    # Verify app exists
    begin
      app = Spaceship::ConnectAPI::App.find(app_id)
      if app
        UI.success("App '#{app_id}' found in App Store Connect")
      else
        UI.important("App '#{app_id}' NOT found in App Store Connect")
      end
    rescue => e
      UI.important("Could not verify app: #{e.message}")
    end

    # Output for parsing
    puts "ITC_TEAM_ID=#{itc_team_id}"
  end

  # ------------------------------------------------------------------
  # Build only (no upload) — useful for local testing
  # ------------------------------------------------------------------
  desc "Build IPA only (no upload)"
  lane :build do
    sync_signing

    app_id = app_identifier_value

    build_app(
      workspace: ios_workspace,
      scheme: ios_scheme,
      export_method: "app-store",
      export_options: appstore_export_options(app_id),
      output_directory: "../build/ios",
      output_name: ipa_output_name,
    )
  end

  # ------------------------------------------------------------------
  # Metadata: Upload only metadata to App Store (no build)
  # ------------------------------------------------------------------
  desc "Upload only metadata to App Store (no build)"
  lane :upload_metadata do
    load_asc_api_key

    deliver(
      app_identifier: app_identifier_value,
      skip_binary_upload: true,
      skip_screenshots: true,
      metadata_path: "./fastlane/metadata",
      force: true,
      precheck_include_in_app_purchases: false,
      ignore_language_directory_validation: true,
    )
  end

  # ------------------------------------------------------------------
  # Screenshots: Upload only screenshots to App Store (no build)
  # ------------------------------------------------------------------
  desc "Upload only screenshots to App Store (no build)"
  lane :upload_screenshots do
    load_asc_api_key

    deliver(
      app_identifier: app_identifier_value,
      skip_binary_upload: true,
      skip_metadata: true,
      screenshots_path: "./fastlane/screenshots/framed",
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end

  # ------------------------------------------------------------------
  # Listing: Upload metadata + screenshots to App Store (no build)
  # ------------------------------------------------------------------
  desc "Upload metadata + screenshots to App Store (no build)"
  lane :upload_listing do
    load_asc_api_key

    deliver(
      app_identifier: app_identifier_value,
      skip_binary_upload: true,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots/framed",
      force: true,
      precheck_include_in_app_purchases: false,
      ignore_language_directory_validation: true,
    )
  end

  # ------------------------------------------------------------------
  # Download: Fetch current metadata from App Store
  # ------------------------------------------------------------------
  desc "Download current metadata from App Store"
  lane :download_metadata do
    load_asc_api_key

    deliver(
      app_identifier: app_identifier_value,
      metadata_path: "./fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      run_precheck_before_submit: false,
      force: true,
      ignore_language_directory_validation: true,
    )
  end

  # ------------------------------------------------------------------
  # Screenshots: Frame raw integration-test screenshots with frameit
  # ------------------------------------------------------------------
  desc "Frame raw iOS screenshots using frameit"
  lane :screenshots do
    frameit(
      path: "./screenshots/raw",
      output_suffix: "_framed",
      white: true,
    )
  end
end
